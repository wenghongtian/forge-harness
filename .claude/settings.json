{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/human-gate.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/branch-doc-check.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-quality.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/doc-sync.js"
          }
        ]
      }
    ]
  }
}
